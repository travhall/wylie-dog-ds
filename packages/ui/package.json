  "scripts": {
    "build": "pnpm build:styles && pnpm build:components",
    "build:components": "tsup",
    "build:styles": "tailwindcss -i ./src/styles/index.css -o ./dist/index.css",
    "clean": "rm -rf .turbo node_modules dist",
    "dev": "pnpm dev:styles & pnpm dev:components",
    "dev:components": "tsup --watch",
    "dev:styles": "tailwindcss -i ./src/styles/index.css -o ./dist/index.css --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:a11y": "eslint 'src/**/*.{ts,tsx}' --ignore-pattern '**/*.test.*' --ignore-pattern '**/__tests__/**' --ignore-pattern '**/accessibility-example.tsx' --ignore-pattern '**/alert.tsx' --ignore-pattern '**/card.tsx' --ignore-pattern '**/breadcrumb.tsx' --ignore-pattern '**/pagination.tsx' --config eslint.config.a11y.js",
    "test": "vitest",
    "test:a11y": "vitest --run --reporter=verbose src/__tests__/*.a11y.test.tsx src/accessibility-validation.test.tsx",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "validate:tokens": "node scripts/validate-token-usage.js"
  },

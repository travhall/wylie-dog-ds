{
  "name": "design-system",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "generate:component": "node scripts/generate-component.js",
    "lint": "turbo run lint",
    "lint:a11y": "turbo run lint:a11y",
    "perf": "./scripts/performance-check.sh",
    "prepare": "husky",
    "preview-storybook": "turbo run preview-storybook",
    "release": "turbo run build --filter=storybook^... && changeset publish --provenance",
    "size": "size-limit",
    "test": "turbo run test",
    "test:a11y": "turbo run test:a11y",
    "test:coverage": "turbo run test:coverage",
    "test:watch": "turbo run test:watch",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.1",
    "size-limit": "^12.0.0",
    "turbo": "^2.8.13",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.28.2"
}

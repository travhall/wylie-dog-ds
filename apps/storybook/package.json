{
  "name": "storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm build:css && storybook build --docs",
    "build:analyze": "pnpm build:css && ANALYZE=true storybook build --docs",
    "build:css": "tailwindcss -i ./src/styles/index.css -o ./dist/storybook.css --minify",
    "clean": "rm -rf .turbo node_modules dist",
    "dev": "pnpm build:css && storybook dev -p 6006",
    "dev:css:watch": "tailwindcss -i ./src/styles/index.css -o ./dist/storybook.css --watch",
    "lint": "eslint \"./stories/**/*.stories.tsx\" --max-warnings 0",
    "preview-storybook": "serve storybook-static"
  },
  "dependencies": {
    "@wyliedog/tokens": "workspace:*",
    "@wyliedog/ui": "workspace:*",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/cli": "^4.2.3",
    "@tailwindcss/postcss": "^4.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-storybook": "10.3.5",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "prettier-plugin-packagejson": "^3.0.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "serve": "^14.2.6",
    "storybook": "^10.3.5",
    "storybook-design-token": "^5.0.0",
    "tailwindcss": "^4.2.3",
    "typescript": "6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
